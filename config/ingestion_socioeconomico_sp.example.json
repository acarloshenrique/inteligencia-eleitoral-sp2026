{
  "pipeline": "medallion",
  "pipeline_version": "medallion_socio_sp_v1",
  "domains": [
    {
      "domain": "eleitoral_oficial",
      "assets": [
        {
          "name": "base_eleitoral_remoto",
          "role": "base_parquet",
          "url": "https://example.com/df_mun_latest.parquet",
          "file_name": "df_mun_latest.parquet",
          "format": "parquet",
          "required": true
        },
        {
          "name": "mapping_tse_ibge",
          "role": "mapping_csv",
