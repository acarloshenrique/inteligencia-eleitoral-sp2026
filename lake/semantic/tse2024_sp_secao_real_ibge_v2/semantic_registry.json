  "metrics": [
    {
      "metric_id": "forca_base",
      "name": "Forca de base",
      "description": "Forca eleitoral do candidato no territorio.",
      "formula": "base_strength_score",
      "grain": "candidate_id + territorio_id",
      "source_table": "gold_electoral_base_strength",
      "source_columns": [
        "base_strength_score"
      ],
      "value_type": "score",
      "owner": "analytics",
      "consumers": [
        "scoring",
        "ranking",
        "dashboard"
      ],
      "quality_notes": "Depende da cobertura de resultados por secao e da qualidade do master index."
    },
    {
      "metric_id": "potencial_expansao",
      "name": "Potencial de expansao",
      "description": "Potencial de crescimento em territorios nao consolidados.",
      "formula": "potencial_expansao_score",
      "grain": "candidate_id + territorio_id",
      "source_table": "gold_priority_score",
      "source_columns": [
        "potencial_expansao_score"
      ],
      "value_type": "score",
      "owner": "analytics",
      "consumers": [
        "scoring",
        "simulador"
      ],
      "quality_notes": ""
    },
    {
      "metric_id": "intensidade_competitiva",
      "name": "Intensidade competitiva",
      "description": "Nivel agregado de competicao local.",
      "formula": "competition_score",
      "grain": "territorio_id",
      "source_table": "gold_competition_landscape",
      "source_columns": [
        "competition_score"
      ],
      "value_type": "score",
      "owner": "analytics",
      "consumers": [
        "scoring",
        "relatorios"
      ],
      "quality_notes": ""
    },
    {
      "metric_id": "aderencia_tematica",
      "name": "Aderencia tematica",
      "description": "Aderencia entre temas e territorio.",
      "formula": "AVG(thematic_affinity_score)",
      "grain": "territorio_id",
      "source_table": "gold_thematic_affinity",
      "source_columns": [
        "thematic_affinity_score"
      ],
      "value_type": "score",
      "owner": "analytics",
      "consumers": [
        "mensagem",
        "copiloto"
      ],
      "quality_notes": ""
    },
    {
      "metric_id": "eficiencia_gasto",
      "name": "Eficiencia de gasto",
      "description": "Eficiencia financeira relativa do candidato.",
      "formula": "finance_efficiency_score",
      "grain": "candidate_id",
      "source_table": "gold_campaign_finance_efficiency",
      "source_columns": [
        "finance_efficiency_score"
      ],
      "value_type": "score",
      "owner": "analytics",
      "consumers": [
        "simulador",
        "allocation"
      ],
      "quality_notes": ""
    },
    {
      "metric_id": "prioridade_territorial",
      "name": "Prioridade territorial",
      "description": "Score final de priorizacao territorial.",
      "formula": "score_prioridade_final",
      "grain": "candidate_id + territorio_id",
      "source_table": "gold_priority_score",
      "source_columns": [
        "score_prioridade_final"
      ],
      "value_type": "score",
      "owner": "analytics",
      "consumers": [
        "ranking",
        "allocation",
        "dashboard"
      ],
      "quality_notes": ""
    },
    {
      "metric_id": "confianca_recomendacao",
      "name": "Confianca da recomendacao",
      "description": "Confianca operacional da recomendacao, baseada em qualidade e score.",
      "formula": "COALESCE(confidence_score, score_prioridade_final * data_quality_score)",
      "grain": "scenario_id + candidate_id + territorio_id",
      "source_table": "gold_allocation_recommendations",
      "source_columns": [
        "score_prioridade_final",
        "percentual_orcamento_sugerido"
      ],
      "value_type": "score",
      "owner": "analytics",
      "consumers": [
        "copiloto",
        "relatorios"
      ],
      "quality_notes": "Quando confidence_score nao existir, usar proxy derivado com cautela."
    },
    {
      "metric_id": "cobertura_territorial",
      "name": "Cobertura territorial",
      "description": "Cobertura de fontes e confiabilidade territorial.",
      "formula": "data_quality_score",
      "grain": "territorio_id",
      "source_table": "gold_territory_profile",
      "source_columns": [
        "data_quality_score"
      ],
      "value_type": "score",
      "owner": "analytics",
      "consumers": [
        "data quality",
        "dashboard"
      ],
      "quality_notes": ""
    },
    {
      "metric_id": "custo_por_voto_estimado",
      "name": "Custo por voto estimado",
      "description": "Despesa total dividida por votos observados do candidato.",
      "formula": "custo_por_voto_estimado",
      "grain": "candidate_id",
      "source_table": "gold_campaign_finance_efficiency",
      "source_columns": [
        "custo_por_voto_estimado"
      ],
      "value_type": "money",
      "owner": "analytics",
      "consumers": [
        "simulador",
        "relatorios"
      ],
      "quality_notes": "Nao deve ser interpretado como custo por secao sem evidencia territorial."
    },
    {
      "metric_id": "share_potencial",
      "name": "Share potencial",
      "description": "Share eleitoral observado ou proxy de potencial relativo.",
      "formula": "historical_vote_share",
      "grain": "candidate_id + territorio_id",
      "source_table": "territorial_recommendation_features",
      "source_columns": [
        "historical_vote_share"
      ],
      "value_type": "ratio",
      "owner": "analytics",
      "consumers": [
        "feature store",
        "scoring"
      ],
      "quality_notes": ""
    }
