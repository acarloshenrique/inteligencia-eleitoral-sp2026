# Ambiente da aplicacao: dev | staging | prod
APP_ENV=dev


# Multi-tenant
# default preserva layout local atual; outros tenants usam ./data/tenants/<tenant_id>/...
TENANT_ID=default

# Raiz dos dados (local/Docker). Se vazio, o app tenta detectar automaticamente.
DATA_ROOT=./data

# Data Lake governado. Estrutura criada automaticamente: bronze/silver/gold/catalog.
DATA_LAKE_ROOT=./data/data_lake

# Chave Groq (opcional se REQUIRE_GROQ_API_KEY=false)
GROQ_API_KEY=

# Controles de bootstrap
# true: exige presenca dos parquets df_mun_*.parquet no startup/readiness
REQUIRE_DATA=false
# true: exige GROQ_API_KEY no startup/readiness
REQUIRE_GROQ_API_KEY=false

# Timestamp preferencial do dataset (opcional)
DF_MUN_TS=20260316_1855

# Porta interna usada pelo healthcheck para validar Streamlit
PORT=7860

# Custo estimado em USD por 1k tokens (telemetria RAG)
RAG_COST_PER_1K_TOKENS_USD=0.00059

# Fila assincrona (API + workers)
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=jobs

# Banco transacional de metadados (jobs/artefatos)
METADATA_DB_PATH=./data/metadata/jobs.sqlite3

# Artefatos (local|s3)
ARTIFACT_BACKEND=local
ARTIFACT_LOCAL_ROOT=./data/artifacts
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=intel-eleitoral
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Cofre de segredos (env|vault)
SECRET_BACKEND=env
VAULT_ADDR=
VAULT_TOKEN=
VAULT_KV_PATH=

# RBAC (JSON com token -> actor/role/expires_at). Armazene no backend de segredos.
# Em APP_ENV=dev, se vazio, existe fallback local dev-admin-token.
# Em staging/prod, API_TOKENS_JSON e obrigatorio, dev-admin-token e proibido e expires_at e exigido.
# Exemplo: {"token-longo-aleatorio":{"actor":"ops-admin","role":"admin","expires_at":"2026-12-31T23:59:59Z"}}
API_TOKENS_JSON=


# Operacao SaaS: agenda e alertas
OPS_DAILY_INGESTION_HOUR=5
OPS_WEEKLY_UPDATE_DAY=MON
OPS_WEEKLY_UPDATE_HOUR=6
OPS_ALERT_ERROR_RATE_THRESHOLD=0.10
OPS_ALERT_LATENCY_P95_MS=30000
OPS_ALERT_DAILY_COST_USD=50
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_SLACK_WEBHOOK_URL=
OPS_ALERT_TEAMS_WEBHOOK_URL=
OPS_ALERT_EMAIL_ENABLED=false
OPS_ALERT_EMAIL_FROM=
OPS_ALERT_EMAIL_TO=
OPS_ALERT_SMTP_HOST=
OPS_ALERT_SMTP_PORT=587
OPS_ALERT_SMTP_USERNAME=
OPS_ALERT_SMTP_PASSWORD=
OPS_ALERT_SMTP_TLS=true

# Hardening de producao
# Em APP_ENV=prod, Redis deve usar TLS e senha por padrao.
REQUIRE_REDIS_TLS_IN_PROD=true
REQUIRE_REDIS_AUTH_IN_PROD=true
# local: volume ChromaDB isolado por tenant; external: servico vetorial gerenciado.
CHROMA_VECTOR_BACKEND=local
CHROMA_ALLOW_SHARED_VOLUME=false

# LGPD
RETENTION_DAYS=180
LGPD_ANONYMIZATION_SALT=change-me
